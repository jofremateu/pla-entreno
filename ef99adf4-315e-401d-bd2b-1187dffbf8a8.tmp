<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pla Entrenament & Nutrició — Jofre</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f7fa;
    --bg2: #ffffff;
    --bg3: #eef1f6;
    --border: #d0d7e3;
    --accent: #1a56db;
    --accent2: #e07820;
    --z1: #1a7fd4;
    --z2: #1a8c4e;
    --z3: #b45309;
    --z4: #c2410c;
    --z5: #be123c;
    --ss: #7c3aed;
    --text: #111827;
    --muted: #4b5563;
    --light: #6b7280;
    --radius: 8px;
    --shadow: 0 1px 4px rgba(0,0,0,0.08);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; font-size: 16px; line-height: 1.7; }

  header {
    background: var(--accent);
    padding: 32px 40px 28px;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .header-left h1 { font-family: 'Space Grotesk', sans-serif; font-size: 38px; font-weight: 700; letter-spacing: -1px; line-height: 1.1; color: #fff; }
  .header-left h1 span { color: #fde68a; }
  .header-left p { color: rgba(255,255,255,0.75); font-size: 14px; margin-top: 6px; }
  .header-stats { display: flex; gap: 16px; flex-wrap: wrap; }
  .stat { text-align: center; background: rgba(255,255,255,0.15); border-radius: var(--radius); padding: 10px 16px; }
  .stat .val { font-family: 'Space Grotesk', sans-serif; font-size: 26px; font-weight: 700; color: #fff; line-height: 1; }
  .stat .lbl { font-size: 11px; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 1px; margin-top: 3px; }

  nav { background: var(--bg2); border-bottom: 2px solid var(--border); padding: 0 40px; display: flex; gap: 0; overflow-x: auto; box-shadow: var(--shadow); }
  nav a { display: block; padding: 16px 20px; font-size: 13px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; color: var(--muted); text-decoration: none; border-bottom: 3px solid transparent; white-space: nowrap; transition: all .2s; }
  nav a:hover, nav a.active { color: var(--accent); border-bottom-color: var(--accent); }

  main { max-width: 1100px; margin: 0 auto; padding: 40px 24px 80px; }
  section { margin-bottom: 60px; }
  h2 { font-family: 'Space Grotesk', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 20px; display: flex; align-items: center; gap: 12px; }
  h2::after { content: ''; flex: 1; height: 2px; background: var(--border); }

  .zones-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
  .zone-card { background: var(--bg2); border: 2px solid var(--border); border-radius: var(--radius); padding: 18px 14px; text-align: center; box-shadow: var(--shadow); }
  .zone-card.z1 { border-top: 4px solid var(--z1); }
  .zone-card.z2 { border-top: 4px solid var(--z2); }
  .zone-card.z3 { border-top: 4px solid var(--z3); }
  .zone-card.z4 { border-top: 4px solid var(--z4); }
  .zone-card.z5 { border-top: 4px solid var(--z5); }
  .zone-card .zname { font-family: 'Space Grotesk', sans-serif; font-size: 30px; font-weight: 700; line-height: 1; }
  .zone-card.z1 .zname { color: var(--z1); }
  .zone-card.z2 .zname { color: var(--z2); }
  .zone-card.z3 .zname { color: var(--z3); }
  .zone-card.z4 .zname { color: var(--z4); }
  .zone-card.z5 .zname { color: var(--z5); }
  .zone-card .zbpm { font-size: 15px; font-weight: 600; color: var(--text); margin: 6px 0; }
  .zone-card .zdesc { font-size: 13px; color: var(--muted); }
  .ss-card { background: #faf5ff; border: 2px solid #ddd6fe; border-left: 5px solid var(--ss); border-radius: var(--radius); padding: 16px 20px; margin-top: 14px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; box-shadow: var(--shadow); }
  .ss-card .sslabel { font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 700; color: var(--ss); }
  .ss-card .ssbpm { font-size: 16px; font-weight: 600; color: var(--text); }
  .ss-card .ssdesc { font-size: 14px; color: var(--muted); }

  .block-tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
  .btab { padding: 10px 22px; border-radius: var(--radius); background: var(--bg2); border: 2px solid var(--border); font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; color: var(--muted); transition: all .2s; box-shadow: var(--shadow); }
  .btab.active { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btab:hover:not(.active) { border-color: var(--accent); color: var(--accent); }
  .block-panel { display: none; }
  .block-panel.active { display: block; }

  .weeks-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px; }
  .week-card { background: var(--bg2); border: 2px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
  .week-card.deload { border-color: #fed7aa; }
  .week-header { padding: 12px 16px; background: var(--bg3); display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--border); }
  .week-card.deload .week-header { background: #fff7ed; border-bottom-color: #fed7aa; }
  .week-header .wnum { font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 700; color: var(--text); }
  .week-header .wtag { font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 3px 8px; border-radius: 4px; }
  .wtag.build { background: #dcfce7; color: #166534; }
  .wtag.deload { background: #fff7ed; color: #9a3412; border: 1px solid #fed7aa; }
  .week-body { padding: 12px 14px; }
  .day-row { display: flex; align-items: flex-start; gap: 10px; padding: 7px 0; border-bottom: 1px solid var(--bg3); font-size: 14px; }
  .day-row:last-child { border-bottom: none; }
  .day-name { font-size: 12px; font-weight: 700; color: var(--muted); min-width: 28px; padding-top: 2px; text-transform: uppercase; }
  .day-session { flex: 1; }
  .day-session small { font-size: 12px; color: var(--muted); display: block; margin-top: 1px; }
  .day-duration { font-size: 13px; font-weight: 600; color: var(--muted); white-space: nowrap; padding-top: 3px; }

  .stype { font-size: 12px; font-weight: 700; display: inline-block; padding: 2px 8px; border-radius: 4px; margin-bottom: 3px; }
  .stype.z2 { background: #dcfce7; color: #166534; }
  .stype.ss { background: #f5f3ff; color: #6d28d9; }
  .stype.z4 { background: #fff7ed; color: #9a3412; }
  .stype.z5 { background: #fff1f2; color: #9f1239; }
  .stype.long { background: #eff6ff; color: #1e40af; }
  .stype.rec { background: var(--bg3); color: var(--muted); }
  .stype.rest { color: var(--light); font-size: 13px; background: none; padding: 0; }

  .block-summary { background: var(--bg2); border: 2px solid var(--border); border-radius: var(--radius); padding: 18px 20px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; box-shadow: var(--shadow); }
  .bsum-item .bsval { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700; color: var(--accent); }
  .bsum-item .bslbl { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }

  .session-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .session-card { background: var(--bg2); border: 2px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
  .sc-header { padding: 14px 18px; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid var(--border); }
  .sc-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
  .sc-title { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 700; color: var(--text); }
  .sc-body { padding: 16px 18px; }
  .sc-body table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .sc-body table tr { border-bottom: 1px solid var(--bg3); }
  .sc-body table tr:last-child { border-bottom: none; }
  .sc-body table td { padding: 8px 0; }
  .sc-body table td:first-child { color: var(--muted); width: 120px; font-size: 13px; font-weight: 500; }
  .sc-note { margin-top: 12px; padding: 10px 14px; background: #fffbeb; border-left: 4px solid #f59e0b; border-radius: 4px; font-size: 13px; color: #78350f; line-height: 1.6; }
  .sc-note.info { background: #eff6ff; border-left-color: var(--accent); color: #1e3a8a; }

  .nutri-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 10px; }
  .nutri-day { background: var(--bg2); border: 2px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
  .nd-head { padding: 10px; text-align: center; font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 700; }
  .nd-head.train { background: #dcfce7; color: #166534; }
  .nd-head.quality { background: #f5f3ff; color: #6d28d9; }
  .nd-head.long { background: #eff6ff; color: #1e40af; }
  .nd-head.rest { background: var(--bg3); color: var(--muted); }
  .nd-head.preload { background: #fef9c3; color: #854d0e; }
  .nd-body { padding: 10px; font-size: 13px; }
  .nutri-row { display: flex; justify-content: space-between; margin-bottom: 5px; }
  .nutri-row .nl { color: var(--muted); font-weight: 500; }
  .nutri-row .nv { font-weight: 700; }
  .nutri-row .nv.hi { color: var(--z2); }
  .nutri-row .nv.mid { color: var(--accent2); }
  .nutri-row .nv.lo { color: var(--muted); }
  .nd-bar { height: 5px; border-radius: 3px; margin-top: 8px; background: var(--bg3); overflow: hidden; }
  .nd-bar-fill { height: 100%; border-radius: 3px; }

  .menu-table { width: 100%; border-collapse: collapse; font-size: 14px; background: var(--bg2); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
  .menu-table th { text-align: left; padding: 12px 16px; background: var(--bg3); color: var(--muted); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; font-weight: 700; border-bottom: 2px solid var(--border); }
  .menu-table td { padding: 12px 16px; border-bottom: 1px solid var(--bg3); vertical-align: top; }
  .menu-table tr:last-child td { border-bottom: none; }
  .menu-table tr:hover td { background: var(--bg3); }
  .menu-table .day-col { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 700; color: var(--text); white-space: nowrap; width: 90px; }
  .critical { background: #fff1f2; border: 1px solid #fecdd3; border-radius: 4px; padding: 2px 8px; display: inline-block; font-size: 12px; font-weight: 700; color: #be123c; }
  .alert { background: #fef9c3; border: 2px solid #fde047; border-radius: var(--radius); padding: 12px 16px; font-size: 14px; color: #713f12; margin-bottom: 14px; font-weight: 500; }
  .info-box { background: #f0f9ff; border: 2px solid #bae6fd; border-radius: var(--radius); padding: 12px 16px; font-size: 14px; color: #0c4a6e; margin-top: 14px; line-height: 1.6; }
  .warn-box { background: #fffbeb; border: 2px solid #fde68a; border-radius: var(--radius); padding: 12px 16px; font-size: 14px; color: #78350f; margin-top: 14px; line-height: 1.6; }

  .generic-table { width: 100%; border-collapse: collapse; font-size: 14px; background: var(--bg2); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
  .generic-table th { padding: 12px 16px; background: var(--bg3); color: var(--muted); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; font-weight: 700; border-bottom: 2px solid var(--border); text-align: left; }
  .generic-table td { padding: 12px 16px; border-bottom: 1px solid var(--bg3); vertical-align: middle; }
  .generic-table tr:last-child td { border-bottom: none; }
  .generic-table tr:hover td { background: var(--bg3); }
  .day-col-gen { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 700; color: var(--text); white-space: nowrap; }

  .principles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .principle { background: var(--bg2); border: 2px solid var(--border); border-radius: var(--radius); padding: 20px; box-shadow: var(--shadow); }
  .principle .pnum { font-family: 'Space Grotesk', sans-serif; font-size: 40px; font-weight: 700; color: var(--border); line-height: 1; margin-bottom: 10px; }
  .principle h4 { font-size: 15px; font-weight: 700; margin-bottom: 8px; color: var(--accent); }
  .principle p { font-size: 14px; color: var(--muted); line-height: 1.7; }

  @media (max-width: 768px) {
    header { padding: 20px; }
    main { padding: 24px 16px 60px; }
    .zones-grid { grid-template-columns: repeat(3, 1fr); }
    .weeks-grid { grid-template-columns: 1fr 1fr; }
    .block-summary { grid-template-columns: repeat(2, 1fr); }
    .session-cards { grid-template-columns: 1fr; }
    .nutri-grid { grid-template-columns: repeat(3, 1fr); }
    .principles { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<header>
  <div class="header-left">
    <h1>PLA ENTRENAMENT<br><span>& NUTRICIÓ</span></h1>
    <p>Jofre · 27 anys · Sant Feliu de Guixols · Garmin Fenix 6 + Cinta pit FC</p>
  </div>
  <div class="header-stats">
    <div class="stat"><div class="val">89<span style="font-size:15px">kg</span></div><div class="lbl">Pes</div></div>
    <div class="stat"><div class="val">176<span style="font-size:15px">cm</span></div><div class="lbl">Alçada</div></div>
    <div class="stat"><div class="val">193<span style="font-size:15px">bpm</span></div><div class="lbl">FCmàx est.</div></div>
    <div class="stat"><div class="val">2450<span style="font-size:15px">kcal</span></div><div class="lbl">Objectiu</div></div>
    <div class="stat"><div class="val">12<span style="font-size:15px">set</span></div><div class="lbl">Durada</div></div>
  </div>
</header>

<nav>
  <a href="#zones" class="active">Zones FC</a>
  <a href="#estructura">Estructura</a>
  <a href="#blocs">Blocs 1–12</a>
  <a href="#sessions">Sessions</a>
  <a href="#nutri">Nutrició</a>
  <a href="#menu">Menú</a>
  <a href="#principis">Principis</a>
</nav>

<main>

<section id="zones">
  <h2>Zones de freqüència cardíaca</h2>
  <div class="zones-grid">
    <div class="zone-card z1"><div class="zname">Z1</div><div class="zbpm">&lt; 116 bpm</div><div class="zdesc">Recuperació activa</div></div>
    <div class="zone-card z2"><div class="zname">Z2</div><div class="zbpm">116–135 bpm</div><div class="zdesc">Base aeròbica</div></div>
    <div class="zone-card z3"><div class="zname">Z3</div><div class="zbpm">136–154 bpm</div><div class="zdesc">Endurance temperat</div></div>
    <div class="zone-card z4"><div class="zname">Z4</div><div class="zbpm">155–174 bpm</div><div class="zdesc">Llindar anaeròbic</div></div>
    <div class="zone-card z5"><div class="zname">Z5</div><div class="zbpm">175–193 bpm</div><div class="zdesc">VO₂ màx</div></div>
  </div>
  <div class="ss-card">
    <div class="sslabel">SWEET SPOT</div>
    <div class="ssbpm">~160–172 bpm</div>
    <div class="ssdesc">Frontera Z3/Z4 · ~88–93% FCmàx · Màxim rendiment per unitat de fatiga · Nucli del Bloc 1 i 2</div>
  </div>
  <div class="warn-box">⚠️ <strong>FCmàx estimada (220 − edat = 193):</strong> Les zones poden estar desviades ±10–12 bpm. Fer un test real de FCmàx en bici per calibrar-les correctament.</div>
</section>

<section id="estructura">
  <h2>Estructura setmanal</h2>
  <table class="generic-table">
    <thead><tr><th>Dia</th><th>Sessió</th><th>Intensitat</th><th>Durada</th><th>CHO</th></tr></thead>
    <tbody>
      <tr><td class="day-col-gen">Dilluns</td><td style="color:var(--muted)">Descans total</td><td>—</td><td style="color:var(--muted)">—</td><td style="color:var(--muted)">2–3 g/kg</td></tr>
      <tr><td class="day-col-gen">Dimarts</td><td style="color:var(--muted)">Descans total</td><td>—</td><td style="color:var(--muted)">—</td><td style="color:var(--muted)">2–3 g/kg</td></tr>
      <tr><td class="day-col-gen">Dimecres</td><td><span class="stype z2">Z2–Z3</span> Endurance aeròbica<br><small style="color:var(--muted); font-size:12px">⚠️ El terreny de SFG fa inevitable el Z3 en repuntes</small></td><td style="color:var(--z2); font-weight:600">116–154 bpm</td><td style="font-weight:600">75–90 min</td><td style="color:var(--muted)">3–4 g/kg</td></tr>
      <tr><td class="day-col-gen">Dijous</td><td><span class="stype ss">Sweet Spot</span> → <span class="stype z4">Z4</span> al Bloc 3</td><td style="color:var(--ss); font-weight:600">160–172 bpm</td><td style="font-weight:600">60–80 min</td><td style="color:var(--muted)">3–4 g/kg</td></tr>
      <tr><td class="day-col-gen">Divendres</td><td>Descans + <strong style="color:#854d0e">pre-càrrega CHO sopar</strong></td><td>—</td><td style="color:var(--muted)">—</td><td style="color:#854d0e; font-weight:600">2–3 g/kg + extra sopar</td></tr>
      <tr><td class="day-col-gen">Dissabte</td><td><span class="stype long">Sortida llarga</span> · 8:30–9h</td><td style="color:var(--z1); font-weight:600">Z2 + Z3 pujades</td><td style="font-weight:600">1.5h → 3h</td><td style="color:var(--z2); font-weight:600">5–6 g/kg</td></tr>
      <tr><td class="day-col-gen">Diumenge</td><td>Opcional — recuperació suau</td><td style="color:var(--z1); font-weight:600">Z1 únicament</td><td style="color:var(--muted)">màx 45 min</td><td style="color:var(--muted)">2–3 g/kg</td></tr>
    </tbody>
  </table>
</section>

<section id="blocs">
  <h2>Progressió 12 setmanes — 3 blocs</h2>
  <div class="block-tabs">
    <button class="btab active" onclick="showBlock(1)">BLOC 1 · Base (Set. 1–4)</button>
    <button class="btab" onclick="showBlock(2)">BLOC 2 · Desenvolupament (Set. 5–8)</button>
    <button class="btab" onclick="showBlock(3)">BLOC 3 · Intensificació (Set. 9–12)</button>
  </div>

  <div class="block-panel active" id="bloc1">
    <div class="weeks-grid">
      <div class="week-card"><div class="week-header"><span class="wnum">SETMANA 1</span><span class="wtag build">BUILD</span></div><div class="week-body"><div class="day-row"><span class="day-name">DC</span><div class="day-session"><span class="stype z2">Z2–Z3</span><small>Endurance aeròbica</small></div><span class="day-duration">75 min</span></div><div class="day-row"><span class="day-name">DJ</span><div class="day-session"><span class="stype ss">Sweet Spot</span><small>2×15 min · rec. 5 min</small></div><span class="day-duration">65 min</span></div><div class="day-row"><span class="day-name">DV</span><div class="day-session"><span class="stype rest">Descans</span></div><span class="day-duration">—</span></div><div class="day-row"><span class="day-name">DS</span><div class="day-session"><span class="stype long">Sortida llarga</span><small>Z2 base</small></div><span class="day-duration">1.5h</span></div><div class="day-row"><span class="day-name">DG</span><div class="day-session"><span class="stype rec">Opcional Z1</span></div><span class="day-duration">45 min</span></div></div></div>
      <div class="week-card"><div class="week-header"><span class="wnum">SETMANA 2</span><span class="wtag build">BUILD</span></div><div class="week-body"><div class="day-row"><span class="day-name">DC</span><div class="day-session"><span class="stype z2">Z2–Z3</span><small>Endurance aeròbica</small></div><span class="day-duration">80 min</span></div><div class="day-row"><span class="day-name">DJ</span><div class="day-session"><span class="stype ss">Sweet Spot</span><small>2×18 min · rec. 5 min</small></div><span class="day-duration">70 min</span></div><div class="day-row"><span class="day-name">DV</span><div class="day-session"><span class="stype rest">Descans</span></div><span class="day-duration">—</span></div><div class="day-row"><span class="day-name">DS</span><div class="day-session"><span class="stype long">Sortida llarga</span><small>Z2 base</small></div><span class="day-duration">2h</span></div><div class="day-row"><span class="day-name">DG</span><div class="day-session"><span class="stype rec">Opcional Z1</span></div><span class="day-duration">45 min</span></div></div></div>
